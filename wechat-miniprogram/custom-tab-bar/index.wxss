.tabbar-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 14rpx 18rpx calc(18rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(241, 246, 252, 0), rgba(241, 246, 252, 0.92) 32%, rgba(239, 244, 250, 0.98));
  z-index: 100;
}

.tabbar-shell {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  align-items: center;
  padding: 10rpx 10rpx 0;
  border-radius: 30rpx;
  border: 1rpx solid rgba(204, 216, 233, 0.9);
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 -10rpx 28rpx rgba(22, 43, 67, 0.06);
}

.tab-item {
  display: grid;
  justify-items: center;
  gap: 8rpx;
  padding: 8rpx 0 12rpx;
  color: #6a7f99;
  font-size: 20rpx;
}

.tab-item.is-active {
  color: var(--brand-primary);
}

.icon-shell {
  position: relative;
  width: 78rpx;
  height: 58rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.is-active .icon-shell {
  background: rgba(233, 241, 252, 0.96);
  box-shadow: inset 0 0 0 1rpx rgba(191, 209, 229, 0.96);
}

.tab-label {
  line-height: 1.2;
}

.tab-item.is-active .tab-label {
  font-weight: 800;
}

.icon-home,
.icon-search,
.icon-knowledge,
.icon-profile {
  position: relative;
  width: 34rpx;
  height: 30rpx;
}

.home-roof {
  position: absolute;
  left: 7rpx;
  top: 0;
  width: 18rpx;
  height: 18rpx;
  border-top: 4rpx solid currentColor;
  border-left: 4rpx solid currentColor;
  transform: rotate(45deg);
  border-top-left-radius: 4rpx;
}

.home-body {
  position: absolute;
  left: 6rpx;
  bottom: 0;
  width: 22rpx;
  height: 16rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 6rpx 6rpx;
}

.search-ring {
  position: absolute;
  left: 4rpx;
  top: 2rpx;
  width: 16rpx;
  height: 16rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.search-handle {
  position: absolute;
  right: 2rpx;
  bottom: 2rpx;
  width: 14rpx;
  height: 4rpx;
  background: currentColor;
  border-radius: 999rpx;
  transform: rotate(45deg);
}

.knowledge-box {
  position: absolute;
  inset: 3rpx 3rpx 9rpx 3rpx;
  border: 4rpx solid currentColor;
  border-radius: 10rpx;
}

.knowledge-tail {
  position: absolute;
  left: 8rpx;
  bottom: 0;
  width: 12rpx;
  height: 12rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  border-bottom-left-radius: 4rpx;
  transform: skewX(-14deg);
}

.profile-head {
  width: 16rpx;
  height: 16rpx;
  margin: 0 auto;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.profile-body {
  width: 24rpx;
  height: 14rpx;
  margin: 4rpx auto 0;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 16rpx 16rpx;
}

.profile-dot {
  position: absolute;
  top: 4rpx;
  right: 6rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #e24a48;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.96);
}