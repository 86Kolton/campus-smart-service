.errand-hero-card {
  background:
    radial-gradient(circle at top right, rgba(36, 79, 131, 0.12), transparent 30%),
    linear-gradient(145deg, #f8fbff, #eef5ff 68%, #f9fcff);
}

.hero-brow {
  display: inline-flex;
  align-items: center;
  min-height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #e7f3ee;
  color: #266656;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-head {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.errand-title {
  font-size: 44rpx;
}

.hero-create-btn {
  flex-shrink: 0;
  min-width: 164rpx;
  padding: 0 22rpx;
}

.hero-sub {
  margin-top: 10rpx;
}

.hero-stats {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.hero-stat {
  border-radius: 24rpx;
  border: 1rpx solid #dae5f2;
  background: rgba(255, 255, 255, 0.86);
  padding: 18rpx 12rpx;
  text-align: center;
  transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
}

.hero-stat.is-active {
  border-color: #b7cbe4;
  background: linear-gradient(180deg, rgba(235, 243, 255, 0.98), rgba(229, 238, 252, 0.96));
  box-shadow: 0 14rpx 30rpx rgba(35, 78, 128, 0.08);
  transform: translateY(-2rpx);
}

.hero-stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #193c61;
}

.hero-stat-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #637b96;
}

.errand-filter-card {
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

.chip-filter {
  min-height: 62rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip-filter.is-active {
  background: #e3eefc;
  border-color: #b8cde6;
  color: #234e80;
  font-weight: 700;
}

.errand-detail-card {
  display: grid;
  gap: 16rpx;
}

.detail-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.detail-brow {
  font-size: 22rpx;
  color: #6b839d;
}

.detail-title {
  margin-top: 8rpx;
  font-size: 34rpx;
  line-height: 1.36;
  font-weight: 700;
  color: #183553;
}

.detail-status {
  flex-shrink: 0;
  min-width: 104rpx;
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-status-blue {
  background: #eaf2ff;
  color: #1c4f86;
}

.detail-status-mint {
  background: #e8f5ef;
  color: #216c53;
}

.detail-status-sand {
  background: #fff5e7;
  color: #9a661d;
}

.detail-status-teal {
  background: #e8f7f4;
  color: #216d63;
}

.detail-status-gray {
  background: #eef2f6;
  color: #607286;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.detail-chip {
  border-radius: 22rpx;
  border: 1rpx solid #dbe5f1;
  background: #f9fbff;
  padding: 16rpx;
}

.detail-chip-label {
  font-size: 22rpx;
  color: #6c829a;
}

.detail-chip-value {
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #183858;
}

.detail-note {
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: #f5f9ff;
  color: #395671;
  font-size: 24rpx;
  line-height: 1.65;
}

.detail-contact-card {
  padding: 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid #d9e5f1;
  background: #f9fbff;
}

.detail-contact-card-soft {
  background: rgba(244, 248, 254, 0.98);
}

.detail-contact-title {
  font-size: 22rpx;
  color: #6b8198;
}

.detail-contact-value {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.48;
  font-weight: 700;
  color: #183858;
}

.detail-contact-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.56;
  color: #6d8197;
}

.timeline-list {
  display: grid;
  gap: 12rpx;
}

.timeline-row {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.timeline-dot {
  width: 18rpx;
  height: 18rpx;
  margin-top: 8rpx;
  border-radius: 50%;
  background: #c4d6ea;
}

.timeline-copy {
  min-width: 0;
}

.timeline-label {
  font-size: 22rpx;
  color: #74899f;
}

.timeline-value {
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #1e3e62;
  font-weight: 700;
}

.detail-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.detail-btn,
.card-btn,
.empty-create-btn {
  width: 100%;
}

.errand-list {
  margin-top: 18rpx;
  display: grid;
  gap: 14rpx;
}

.errand-card {
  margin-top: 0;
  display: grid;
  gap: 12rpx;
  border-color: #d9e5f1;
}

.errand-card.is-selected {
  border-color: #b9cee6;
  box-shadow: 0 16rpx 32rpx rgba(37, 60, 88, 0.1);
}

.errand-card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.errand-card-title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  line-height: 1.36;
  font-weight: 700;
  color: #193451;
}

.errand-reward {
  flex-shrink: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #1d6f59;
}

.errand-card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  font-size: 22rpx;
  color: #6d8197;
}

.errand-location {
  font-size: 24rpx;
  line-height: 1.58;
  color: #355372;
}

.errand-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag-chip,
.status-chip {
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.tag-chip {
  background: #eef7f2;
  color: #256d54;
}

.status-chip-blue {
  background: #eaf2ff;
  color: #1d4f86;
}

.status-chip-mint {
  background: #e8f5ef;
  color: #216c53;
}

.status-chip-sand {
  background: #fff5e7;
  color: #9a661d;
}

.status-chip-teal {
  background: #e8f7f4;
  color: #216d63;
}

.status-chip-gray {
  background: #eef2f6;
  color: #607286;
}

.errand-note {
  font-size: 24rpx;
  line-height: 1.62;
  color: #405974;
}

.errand-contact {
  font-size: 22rpx;
  color: #6f8299;
}

.errand-card-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
}

.errand-empty-card {
  margin-top: 0;
  display: grid;
  gap: 14rpx;
}
