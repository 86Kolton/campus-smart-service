.account-hero {
  background: linear-gradient(145deg, rgba(249, 252, 255, 0.98), rgba(237, 245, 255, 0.94));
}

.account-stack {
  display: grid;
  gap: 16rpx;
}

.account-row {
  min-height: 72rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0;
  border-top: 1rpx solid rgba(228, 236, 245, 0.96);
}

.account-row:first-child {
  border-top: 0;
}

.account-label {
  font-size: 24rpx;
  color: var(--ink-500);
}

.account-value {
  font-size: 26rpx;
  font-weight: 800;
  color: var(--ink-950);
}

.account-preview {
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(205, 217, 233, 0.98);
  background: rgba(244, 249, 255, 0.96);
}

.account-preview-label {
  font-size: 22rpx;
  color: var(--ink-500);
}

.account-preview-value {
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--brand-primary);
}

.account-submit {
  width: 100%;
}