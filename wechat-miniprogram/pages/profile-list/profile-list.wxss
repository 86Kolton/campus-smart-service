.profile-list-hero {
  display: grid;
  gap: 18rpx;
}

.profile-list-stack {
  display: grid;
  gap: 14rpx;
  margin-top: 18rpx;
}

.error-stack {
  display: grid;
  gap: 16rpx;
}

.retry-btn {
  width: 100%;
}

.profile-post-row {
  margin-top: 0;
  display: grid;
  gap: 12rpx;
}

.profile-post-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.profile-post-title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  line-height: 1.42;
  font-weight: 800;
  color: var(--ink-950);
}

.profile-post-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid rgba(136, 160, 184, 0.98);
  border-right: 3rpx solid rgba(136, 160, 184, 0.98);
  transform: rotate(45deg);
}

.profile-post-content {
  font-size: 26rpx;
  line-height: 1.68;
  color: var(--ink-800);
}

.profile-post-location {
  font-size: 23rpx;
  line-height: 1.56;
  color: var(--ink-700);
}

.profile-post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.profile-post-meta {
  font-size: 22rpx;
  color: var(--ink-500);
}

.profile-post-action {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--brand-primary);
}

.profile-post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.profile-post-tag {
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(204, 216, 233, 0.98);
  background: rgba(239, 246, 255, 0.96);
  color: var(--ink-800);
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
