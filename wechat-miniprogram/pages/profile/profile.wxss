.card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.card-section-title {
  font-size: 36rpx;
}

.profile-hero {
  display: grid;
  gap: 20rpx;
}

.profile-hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.profile-hero-action {
  min-height: 58rpx;
  padding: 0 20rpx;
  font-size: 22rpx;
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #21415f, #476887);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 40rpx;
  line-height: 1.18;
  font-weight: 800;
  color: var(--ink-950);
}

.profile-meta {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.56;
  color: var(--ink-700);
}

.bind-state {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--brand-primary);
}

.public-name-strip {
  display: grid;
  gap: 8rpx;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(204, 216, 233, 0.98);
  background: linear-gradient(180deg, rgba(252, 253, 255, 0.98), rgba(244, 249, 255, 0.92));
}

.public-name-label {
  font-size: 22rpx;
  color: var(--ink-500);
}

.public-name-value {
  margin-top: 8rpx;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 800;
  color: var(--ink-950);
}

.public-name-desc {
  font-size: 23rpx;
  line-height: 1.6;
  color: var(--ink-700);
}

.stats-card {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.stat-item {
  min-height: 154rpx;
  padding: 22rpx 20rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(206, 219, 235, 0.98);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 249, 255, 0.92));
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 800;
  color: var(--ink-950);
}

.stat-label {
  font-size: 24rpx;
  color: var(--ink-700);
}

.stat-link {
  font-size: 22rpx;
  color: var(--ink-500);
}

.inbox-card {
  display: grid;
  gap: 12rpx;
}

.inbox-row {
  min-height: 132rpx;
  padding: 20rpx 22rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(207, 220, 236, 0.98);
  background: linear-gradient(180deg, rgba(252, 253, 255, 0.98), rgba(246, 250, 255, 0.92));
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.inbox-left {
  min-width: 0;
  display: grid;
  gap: 6rpx;
}

.inbox-title {
  font-size: 29rpx;
  line-height: 1.34;
  font-weight: 800;
  color: var(--ink-950);
}

.inbox-sub {
  font-size: 24rpx;
  line-height: 1.54;
  color: var(--ink-700);
}

.inbox-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.inbox-count {
  min-width: 56rpx;
  height: 48rpx;
  padding: 0 14rpx;
  border-radius: 18rpx;
  background: rgba(236, 244, 252, 0.98);
  color: var(--ink-800);
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.row-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid rgba(136, 160, 184, 0.98);
  border-right: 3rpx solid rgba(136, 160, 184, 0.98);
  transform: rotate(45deg);
}

.inbox-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #e24a48;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.96);
}

.edu-card-action {
  flex-shrink: 0;
}

.edu-note {
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(209, 232, 220, 0.98);
  background: rgba(236, 248, 243, 0.98);
  color: #2a5c4f;
  font-size: 24rpx;
  line-height: 1.62;
}

.edu-session-line {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(203, 217, 235, 0.98);
  background: linear-gradient(180deg, rgba(252, 253, 255, 0.98), rgba(245, 249, 255, 0.92));
  font-size: 24rpx;
  line-height: 1.58;
  color: var(--ink-800);
  font-weight: 700;
}

.edu-stat-strip {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.edu-stat-pill {
  min-height: 112rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(203, 217, 235, 0.98);
  background: linear-gradient(180deg, rgba(252, 253, 255, 0.98), rgba(245, 249, 255, 0.92));
  display: grid;
  align-content: center;
  gap: 8rpx;
}

.edu-stat-pill-label {
  font-size: 22rpx;
  color: var(--ink-500);
}

.edu-stat-pill-value {
  font-size: 34rpx;
  line-height: 1.18;
  font-weight: 800;
  color: var(--ink-950);
}

.edu-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.edu-item {
  min-height: 132rpx;
  padding: 18rpx 14rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(204, 216, 233, 0.98);
  background: linear-gradient(180deg, rgba(248, 251, 255, 0.98), rgba(239, 245, 253, 0.94));
}

.edu-item-rich {
  min-height: 204rpx;
  padding: 20rpx 18rpx;
  text-align: left;
}

.edu-item-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.edu-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: rgba(220, 232, 248, 0.98);
  color: var(--brand-primary);
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edu-item-badge {
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(232, 246, 239, 0.98);
  color: #23695e;
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.edu-name {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.32;
  font-weight: 800;
  color: var(--ink-950);
}

.edu-item-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.58;
  color: var(--ink-700);
}

.menu-card {
  display: grid;
  gap: 0;
}

.menu-row {
  min-height: 88rpx;
  border-top: 1rpx solid rgba(228, 236, 245, 0.96);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: var(--ink-950);
}

.menu-row:first-child {
  border-top: 0;
}

.menu-hint {
  font-size: 24rpx;
  color: var(--ink-500);
}

.usage-line {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.66;
  color: var(--ink-800);
}
