<view class="page-shell">
  <view class="global-head">
    <view class="assistant-mini">校园助手</view>
    <view class="online-pill">实时联机</view>
  </view>

  <view class="hello-title">你好，{{greetingName}}</view>
  <view class="hello-sub">{{greetingDate}}</view>

  <view class="card profile-hero">
    <view class="profile-hero-top">
      <view class="section-kicker">身份档案</view>
      <button class="text-btn profile-hero-action" size="mini" bindtap="openAccount">修改显示名</button>
    </view>

    <view class="profile-main">
      <view class="profile-avatar">{{avatarText}}</view>
      <view class="profile-copy">
        <view class="profile-name">{{displayName || (summary ? summary.name : '赵毅')}}</view>
        <view class="profile-meta">{{summary ? summary.meta : '河北大学 · 软件工程 2022 级'}}</view>
        <view class="bind-state">{{summary ? summary.bind_state : '未绑定微信身份'}}</view>
      </view>
    </view>

    <view class="public-name-strip">
      <view>
        <view class="public-name-label">公开显示名</view>
        <view class="public-name-value">{{summary ? summary.public_name : '赵同学'}}</view>
      </view>
      <view class="public-name-desc">帖子、评论和消息提醒里只显示这个公开昵称。</view>
    </view>
  </view>

  <view class="card stats-card">
    <view class="stat-item" data-mode="my" bindtap="onTapStat">
      <view class="stat-value">{{summary ? summary.posts : 0}}</view>
      <view class="stat-label">我的发布</view>
      <view class="stat-link">查看记录</view>
    </view>
    <view class="stat-item" data-mode="likes" bindtap="onTapStat">
      <view class="stat-value">{{summary ? summary.likes : 0}}</view>
      <view class="stat-label">收到的赞</view>
      <view class="stat-link">查看提醒</view>
    </view>
  </view>

  <view class="card inbox-card">
    <view class="card-head">
      <view>
        <view class="section-title card-section-title">消息中心</view>
        <view class="section-caption">点赞提醒和收藏列表都在这里统一查看。</view>
      </view>
      <button class="text-btn" size="mini" bindtap="markAllRead">全部已读</button>
    </view>

    <view wx:for="{{inboxCards}}" wx:key="id" class="inbox-row" data-type="{{item.id}}" bindtap="openInbox">
      <view class="inbox-left">
        <view class="inbox-title">{{item.title}}</view>
        <view class="inbox-sub">{{item.subtitle}}</view>
      </view>
      <view class="inbox-right">
        <view class="inbox-count">{{item.count}}</view>
        <view class="row-arrow"></view>
        <view wx:if="{{item.unread > 0}}" class="inbox-dot"></view>
      </view>
    </view>
  </view>

  <view class="card edu-card">
    <view class="card-head">
      <view>
        <view class="section-title card-section-title">教务大厅</view>
        <view class="section-caption">成绩、课表、考试和空教室统一放到受控教务会话里查看，不进入公开知识库。</view>
      </view>
      <button class="text-btn edu-card-action" size="mini" bindtap="openEduHall">进入大厅</button>
    </view>

    <view class="edu-note">成绩查询当前使用模拟数据；课表、考试和空教室仍走独立会话展示，不参与公开检索、推荐和自进化入库。</view>

    <view class="edu-session-line">{{eduSessionLine}}</view>

    <view class="edu-stat-strip">
      <view
        wx:for="{{eduStats}}"
        wx:key="label"
        class="edu-stat-pill"
        data-action="{{item.action}}"
        bindtap="onTapEdu"
      >
        <view class="edu-stat-pill-label">{{item.label}}</view>
        <view class="edu-stat-pill-value">{{item.value}}</view>
      </view>
    </view>

    <view class="edu-grid edu-grid-rich">
      <view wx:for="{{eduQuickItems}}" wx:key="action" class="edu-item edu-item-rich" data-action="{{item.action}}" bindtap="onTapEdu">
        <view class="edu-item-top">
          <view class="edu-icon">{{item.icon}}</view>
          <view class="edu-item-badge">{{item.badge}}</view>
        </view>
        <view class="edu-name">{{item.title}}</view>
        <view class="edu-item-sub">{{item.sub}}</view>
      </view>
    </view>
  </view>

  <view class="card menu-card">
    <view class="menu-row" data-action="myPosts" bindtap="onTapMenu"><text>我的帖子</text><text class="menu-hint">进入</text></view>
    <view class="menu-row" data-action="likedPosts" bindtap="onTapMenu"><text>我的点赞</text><text class="menu-hint">进入</text></view>
    <view class="menu-row" data-action="publicName" bindtap="onTapMenu"><text>发言显示名</text><text class="menu-hint">{{summary ? summary.public_name : '赵同学'}}</text></view>
    <view class="menu-row" data-action="webLogin" bindtap="onTapMenu"><text>网页互通登录</text><text class="menu-hint">进入</text></view>
    <view class="menu-row" data-action="wechatBind" bindtap="onTapMenu"><text>微信登录/绑定</text><text class="menu-hint">{{summary && summary.wechat_bound ? '已绑定' : '未绑定'}}</text></view>
    <view class="menu-row" data-action="privacy" bindtap="onTapMenu"><text>公开展示说明</text><text class="menu-hint">查看</text></view>
  </view>

  <view class="card usage-card">
    <view class="section-title card-section-title">使用说明</view>
    <view class="usage-line">1. 首页负责帖子流、热帖和快捷入口，发帖入口只保留在首页。</view>
    <view class="usage-line">2. 搜索页只搜索论坛帖子，不和知识库问答混用。</view>
    <view class="usage-line">3. 知识库页支持来源回溯，问答和论坛帖子分开处理。</view>
    <view class="usage-line">4. 教务数据只在受控会话中展示，不参与公开知识库检索和推荐。</view>
  </view>

  <view wx:if="{{loading}}" class="card empty">加载中...</view>
  <view wx:if="{{error}}" class="card empty">{{error}}</view>
</view>
