.search-card {
  background: linear-gradient(145deg, rgba(249, 252, 255, 0.98), rgba(236, 244, 255, 0.94));
}

.search-title,
.list-title {
  font-size: 38rpx;
}

.search-sub {
  margin-top: 12rpx;
}

.search-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-field {
  flex: 1;
  min-width: 0;
}

.search-input {
  min-height: 82rpx;
  line-height: 82rpx;
  border-radius: 24rpx;
}

.search-btn {
  flex: 0 0 124rpx;
  width: 124rpx;
  height: 82rpx;
  min-height: 82rpx;
  padding: 0;
  font-size: 26rpx;
  letter-spacing: 0;
}

.head-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.clear-btn {
  min-height: 58rpx;
  padding: 0 20rpx;
}

.recents-row {
  margin-top: 18rpx;
}

.recent-chip {
  background: rgba(249, 252, 255, 0.98);
}

.empty-inline {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--ink-500);
}

.category-row {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.category-item {
  min-height: 152rpx;
  padding: 18rpx 12rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(203, 216, 233, 0.98);
  background: linear-gradient(180deg, rgba(248, 251, 255, 0.98), rgba(239, 245, 253, 0.94));
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 12rpx;
}

.category-icon {
  width: 62rpx;
  height: 62rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--brand-primary);
}

.category-icon-blue {
  background: rgba(220, 232, 248, 0.98);
}

.category-icon-mint {
  background: rgba(228, 241, 234, 0.98);
}

.category-icon-sand {
  background: rgba(246, 234, 218, 0.98);
}

.category-icon-pink {
  background: rgba(244, 231, 236, 0.98);
}

.category-name {
  font-size: 24rpx;
  line-height: 1.4;
  color: var(--ink-800);
  text-align: center;
}

.result-card {
  padding-bottom: 20rpx;
}

.result-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.result-meta {
  display: grid;
  justify-items: end;
  gap: 10rpx;
  font-size: 23rpx;
  color: var(--ink-700);
}

.sort-switch {
  display: flex;
  gap: 8rpx;
}

.btn-pill {
  min-height: 56rpx;
  padding: 0 20rpx;
  font-size: 23rpx;
}

.btn-pill.active {
  border-color: rgba(165, 192, 220, 0.98);
  background: rgba(231, 240, 251, 0.98);
  color: var(--brand-primary);
}

.result-item {
  margin-top: 16rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(214, 225, 239, 0.96);
}

.item-title {
  font-size: 30rpx;
  line-height: 1.4;
  color: var(--ink-950);
  font-weight: 800;
}

.item-content {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.66;
  color: var(--ink-800);
}

.item-extra {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--ink-500);
}

.pager {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.pager-btn {
  min-height: 60rpx;
  padding: 0 24rpx;
}

.pager-center {
  flex: 1;
  text-align: center;
  font-size: 23rpx;
  color: var(--ink-700);
}

.rank-card {
  padding-bottom: 12rpx;
}

.rank-row {
  margin-top: 10rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(214, 225, 239, 0.96);
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.rank-index {
  width: 44rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #d46a3c;
}

.rank-main {
  flex: 1;
  min-width: 0;
}

.rank-title {
  font-size: 28rpx;
  line-height: 1.42;
  color: var(--ink-950);
  font-weight: 700;
}

.rank-hint {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: var(--ink-500);
}

.rank-heat {
  font-size: 23rpx;
  color: var(--ink-700);
}
