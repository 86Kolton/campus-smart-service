.hero-card,
.compose-card {
  display: grid;
  gap: 18rpx;
}

.hero-card {
  background: linear-gradient(145deg, rgba(249, 252, 255, 0.98), rgba(237, 245, 255, 0.94));
}

.type-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.type-chip {
  min-height: 62rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d6e1ef;
  background: #f8fbff;
  color: #48637f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.type-chip.is-active {
  border-color: #b9cfe7;
  background: #e7f0fe;
  color: #244f83;
  font-weight: 700;
}

.field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.field-stack {
  display: grid;
  gap: 10rpx;
}

.field-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #23415f;
}

.errand-textarea {
  min-height: 168rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid #c9d7e8;
  background: #f6f9fe;
  color: #203854;
  font-size: 26rpx;
  line-height: 1.6;
}

.field-help {
  font-size: 22rpx;
  line-height: 1.56;
  color: var(--ink-500);
}

.submit-btn {
  width: 100%;
}