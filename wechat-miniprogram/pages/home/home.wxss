.status-card {
  background: linear-gradient(180deg, rgba(249, 252, 255, 0.98), rgba(239, 246, 255, 0.92));
}

.hot-card {
  padding-bottom: 10rpx;
}

.hot-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.hot-topic {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.58;
  color: var(--ink-700);
}

.hot-badge {
  min-width: 108rpx;
  min-height: 60rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #b3542f;
  background: rgba(248, 226, 214, 0.98);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.hot-row {
  margin-top: 10rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(214, 225, 239, 0.96);
  display: grid;
  grid-template-columns: 54rpx 1fr auto;
  gap: 16rpx;
  align-items: center;
}

.rank {
  font-size: 36rpx;
  font-weight: 800;
  color: #d46a3c;
  text-align: center;
}

.hot-main {
  min-width: 0;
}

.hot-title {
  font-size: 28rpx;
  line-height: 1.46;
  color: var(--ink-950);
  font-weight: 700;
}

.hot-views {
  font-size: 24rpx;
  color: var(--ink-700);
}

.feed-toolbar {
  background: linear-gradient(180deg, rgba(252, 253, 255, 0.98), rgba(244, 249, 255, 0.92));
}

.feed-toolbar-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.feed-title {
  font-size: 36rpx;
}

.filter-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-chip {
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(204, 216, 233, 0.98);
  background: rgba(255, 255, 255, 0.92);
  color: var(--ink-700);
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.filter-chip.is-active {
  border-color: rgba(165, 192, 220, 0.98);
  background: rgba(231, 240, 251, 0.98);
  color: var(--brand-primary);
  font-weight: 800;
}

.feed-list {
  margin-top: 12rpx;
  display: grid;
  gap: 14rpx;
}

.post-card {
  margin-top: 0;
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(253, 254, 255, 0.98), rgba(246, 250, 255, 0.92));
}

.author-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, rgba(233, 242, 255, 0.98), rgba(219, 232, 249, 0.98));
  color: var(--brand-primary);
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.author-meta {
  flex: 1;
  min-width: 0;
}

.author-name {
  font-size: 26rpx;
  line-height: 1.3;
  font-weight: 800;
  color: var(--ink-950);
}

.time {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--ink-500);
}

.post-title {
  margin-top: 16rpx;
  font-size: 34rpx;
  line-height: 1.34;
  font-weight: 800;
  color: var(--ink-950);
}

.post-content {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--ink-800);
}

.post-thread-preview {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(199, 216, 238, 0.98);
  background: rgba(244, 249, 255, 0.98);
  display: grid;
  gap: 8rpx;
}

.preview-line {
  font-size: 23rpx;
  line-height: 1.54;
  color: #33516f;
  font-weight: 600;
}

.post-badges {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.post-badge {
  min-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.post-badge.adopted {
  color: #196d4c;
  background: rgba(227, 245, 238, 0.98);
}

.post-badge.knowledge {
  color: var(--brand-primary);
  background: rgba(229, 238, 251, 0.98);
}

.post-badge.synced {
  color: #755414;
  background: rgba(249, 240, 220, 0.98);
}

.tags {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--ink-500);
}

.post-actions {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.btn-action {
  position: relative;
  min-height: 70rpx;
  border-radius: 999rpx;
  border: none;
  background: linear-gradient(180deg, rgba(231, 240, 251, 0.98), rgba(220, 232, 248, 0.96));
  color: var(--brand-primary-strong);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 70rpx;
  box-shadow: 0 12rpx 24rpx rgba(26, 57, 92, 0.08);
}

.btn-action::after {
  border: none;
}

.btn-action-like {
  background: linear-gradient(180deg, rgba(231, 240, 251, 0.98), rgba(220, 232, 248, 0.96));
}

.btn-action.is-on {
  background: linear-gradient(180deg, rgba(227, 245, 238, 0.98), rgba(214, 239, 229, 0.96));
  color: #166b4a;
}

.btn-action-comment {
  background: linear-gradient(180deg, rgba(203, 224, 248, 0.98), rgba(181, 209, 242, 0.98));
  color: #133b63;
  box-shadow: 0 14rpx 28rpx rgba(24, 63, 104, 0.14);
}

.empty-card {
  margin-top: 0;
}
