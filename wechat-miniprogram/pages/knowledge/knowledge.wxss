.knowledge-page {
  box-sizing: border-box;
  display: grid;
  grid-template-rows: auto auto minmax(0, 1fr);
  gap: 18rpx;
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  padding: calc(104rpx + env(safe-area-inset-top)) 26rpx calc(132rpx + env(safe-area-inset-bottom));
}

.knowledge-hero {
  display: grid;
  gap: 10rpx;
}

.knowledge-banner {
  justify-self: start;
  display: inline-flex;
  align-items: center;
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(228, 245, 239, 0.98);
  color: #1f8070;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.knowledge-stage {
  min-height: 0;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  gap: 18rpx;
  padding: 28rpx 26rpx 24rpx;
}

.chat-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.chat-title {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 800;
  color: var(--ink-950);
}

.chat-status {
  min-height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(240, 245, 252, 0.96);
  color: var(--ink-700);
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.chat-status-active {
  background: rgba(229, 240, 252, 0.98);
  color: var(--brand-primary);
}

.chat-board {
  min-height: 0;
  border-radius: 30rpx;
  border: 1rpx solid rgba(205, 218, 234, 0.96);
  background: linear-gradient(180deg, rgba(251, 253, 255, 0.98), rgba(243, 248, 255, 0.92));
  padding: 18rpx;
}

.chat-board-scroll {
  min-height: 0;
  height: 100%;
}

.chat-board-empty {
  min-height: 100%;
}

.msg-row {
  display: flex;
  margin-bottom: 22rpx;
}

.msg-row:last-child {
  margin-bottom: 0;
}

.msg-row-user {
  justify-content: flex-end;
}

.msg-row-assistant {
  justify-content: flex-start;
}

.msg-shell {
  display: grid;
  gap: 10rpx;
  max-width: 92%;
}

.msg-shell-user {
  justify-items: end;
}

.msg-shell-assistant {
  justify-items: start;
}

.msg-meta {
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.msg-meta-assistant {
  background: rgba(228, 245, 239, 0.96);
  color: #23695e;
}

.msg-meta-user {
  background: rgba(230, 238, 251, 0.96);
  color: var(--brand-primary);
}

.msg {
  width: fit-content;
  max-width: 100%;
  padding: 20rpx 22rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(206, 220, 237, 0.98);
}

.msg-user {
  background: linear-gradient(145deg, var(--brand-primary), #2a638c);
  border-color: transparent;
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(31, 77, 127, 0.2);
}

.msg-assistant {
  background: rgba(255, 255, 255, 0.96);
}

.msg-text {
  font-size: 26rpx;
  line-height: 1.68;
  white-space: pre-wrap;
  word-break: break-word;
}

.qa-detail-wrap {
  display: grid;
  gap: 12rpx;
  margin-top: 14rpx;
}

.detail-toggle,
.detail-link {
  justify-self: start;
  min-height: 52rpx;
  padding: 0 18rpx;
  font-size: 22rpx;
}

.detail-panel {
  display: grid;
  gap: 12rpx;
  padding: 4rpx 0 0;
}

.detail-item {
  display: grid;
  gap: 10rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(214, 225, 240, 0.94);
  background: rgba(255, 255, 255, 0.98);
}

.detail-title {
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.5;
  color: var(--ink-950);
  word-break: break-all;
}

.detail-snippet {
  font-size: 23rpx;
  line-height: 1.58;
  color: var(--ink-800);
  word-break: break-word;
}

.detail-footer {
  display: grid;
  gap: 12rpx;
}

.detail-meta {
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--ink-700);
  word-break: break-all;
}

.composer-shell {
  display: grid;
  gap: 14rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(220, 230, 242, 0.9);
}

.composer-toolbar {
  display: flex;
  justify-content: flex-start;
}

.deep-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.deep-copy {
  display: grid;
  gap: 0;
}

.deep-title {
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 800;
  color: var(--ink-950);
}

.deep-pill-on .deep-title {
  color: var(--brand-primary);
}

.ask-input {
  min-height: 88rpx;
  height: 88rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  line-height: 1.58;
  border-radius: 24rpx;
  border: 1rpx solid rgba(197, 212, 230, 0.92);
  background: rgba(250, 252, 255, 0.96);
}

.composer-foot {
  display: grid;
}

.ask-btn {
  width: 100%;
  min-height: 72rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
}

.detail-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  background: rgba(15, 28, 45, 0.18);
}

.detail-sheet {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: calc(118rpx + env(safe-area-inset-bottom));
  display: grid;
  gap: 18rpx;
  padding: 24rpx 22rpx 20rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(209, 221, 237, 0.98);
  background: rgba(249, 252, 255, 0.99);
  box-shadow: 0 28rpx 72rpx rgba(23, 47, 80, 0.2);
}

.detail-sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-sheet-copy {
  display: grid;
  gap: 6rpx;
}

.detail-sheet-kicker {
  font-size: 22rpx;
  font-weight: 700;
  color: #4c6583;
}

.detail-sheet-title {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 800;
  color: var(--ink-950);
}

.detail-sheet-close {
  min-height: 52rpx;
  padding: 0 18rpx;
  font-size: 22rpx;
}

.detail-sheet-scroll {
  max-height: 56vh;
}

@media (max-width: 640rpx) {
  .knowledge-page {
    gap: 16rpx;
    padding-bottom: calc(124rpx + env(safe-area-inset-bottom));
  }

  .knowledge-banner {
    font-size: 23rpx;
    padding: 0 18rpx;
  }

  .chat-head {
    align-items: flex-start;
  }

  .msg-shell {
    max-width: 100%;
  }

  .detail-sheet {
    left: 14rpx;
    right: 14rpx;
    bottom: calc(110rpx + env(safe-area-inset-bottom));
  }
}
