page {
  --bg-shell-top: #edf3fb;
  --bg-shell-mid: #e2ebf5;
  --bg-shell-bottom: #d8e3ef;
  --surface-main: rgba(255, 255, 255, 0.94);
  --surface-soft: rgba(245, 249, 255, 0.9);
  --line-soft: rgba(197, 212, 230, 0.88);
  --line-strong: rgba(173, 195, 219, 0.98);
  --ink-950: #173556;
  --ink-800: #355372;
  --ink-700: #57708d;
  --ink-500: #7b8fa6;
  --brand-primary: #1f4d7f;
  --brand-primary-strong: #173d66;
  --brand-soft: #e6effb;
  --brand-teal: #2f8c82;
  --brand-teal-soft: #e4f5f2;
  --warm-soft: #fff0dc;
  --mint-soft: #ebf7ef;
  --rose-soft: #fff0f2;
  --shadow-card: 0 20rpx 48rpx rgba(28, 54, 87, 0.08);
  --shadow-float: 0 24rpx 56rpx rgba(26, 66, 86, 0.2);

  background:
    radial-gradient(circle at left top, rgba(224, 110, 60, 0.13), transparent 34%),
    radial-gradient(circle at right top, rgba(47, 140, 130, 0.12), transparent 30%),
    linear-gradient(180deg, var(--bg-shell-top) 0%, var(--bg-shell-mid) 48%, var(--bg-shell-bottom) 100%);
  color: var(--ink-950);
  font-size: 26rpx;
  min-height: 100%;
  font-family: "HarmonyOS Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
}

page,
view,
text,
button,
input,
textarea,
scroll-view,
image,
switch {
  box-sizing: border-box;
}

.page-shell,
.page-wrap {
  min-height: 100%;
  padding: calc(104rpx + env(safe-area-inset-top)) 26rpx calc(220rpx + env(safe-area-inset-bottom));
}

.page-wrap-sub {
  padding-top: calc(24rpx + env(safe-area-inset-top));
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
}

.global-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.assistant-mini {
  font-size: 28rpx;
  letter-spacing: 1rpx;
  color: var(--ink-700);
}

.online-pill {
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(228, 245, 242, 0.96);
  border: 1rpx solid rgba(176, 220, 213, 0.92);
  color: #23695e;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.hello-title {
  margin-top: 22rpx;
  font-size: 62rpx;
  line-height: 1.08;
  font-weight: 800;
  letter-spacing: -1rpx;
  color: var(--ink-950);
}

.hello-sub {
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.52;
  color: var(--ink-700);
}

.surface-card,
.card {
  margin-top: 18rpx;
  padding: 28rpx;
  border-radius: 34rpx;
  border: 1rpx solid var(--line-soft);
  background: linear-gradient(180deg, var(--surface-main), var(--surface-soft));
  box-shadow: var(--shadow-card);
}

.section-kicker,
.subpage-brow {
  display: inline-flex;
  align-items: center;
  min-height: 46rpx;
  width: fit-content;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(227, 244, 239, 0.96);
  color: #23695e;
  font-size: 22rpx;
  font-weight: 700;
}

.section-title,
.title,
.subpage-title {
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 800;
  letter-spacing: -0.6rpx;
  color: var(--ink-950);
}

.section-sub,
.sub,
.subpage-sub {
  margin-top: 10rpx;
  color: var(--ink-700);
  font-size: 27rpx;
  line-height: 1.68;
}

.section-caption {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.56;
  color: var(--ink-500);
}

.subpage-head {
  display: grid;
  gap: 12rpx;
}

.subpage-stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.subpage-stat-card {
  min-height: 144rpx;
  padding: 20rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(199, 214, 232, 0.92);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(245, 249, 255, 0.92));
}

.subpage-stat-label {
  font-size: 22rpx;
  color: var(--ink-500);
}

.subpage-stat-value {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
  color: var(--ink-950);
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 16rpx;
}

.tile {
  min-height: 160rpx;
  padding: 22rpx 20rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(211, 223, 237, 0.92);
  box-shadow: 0 12rpx 26rpx rgba(29, 49, 74, 0.05);
}

.tile-title {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 800;
  color: var(--ink-950);
}

.tile-sub {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.58;
  color: var(--ink-700);
}

.tile-blue {
  background: linear-gradient(180deg, rgba(235, 243, 255, 0.98), rgba(227, 238, 252, 0.92));
}

.tile-sand {
  background: linear-gradient(180deg, rgba(255, 246, 230, 0.98), rgba(255, 240, 209, 0.92));
}

.tile-mint {
  background: linear-gradient(180deg, rgba(236, 248, 240, 0.98), rgba(226, 244, 233, 0.92));
}

.tile-pink {
  background: linear-gradient(180deg, rgba(255, 242, 245, 0.98), rgba(252, 232, 236, 0.92));
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  min-height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(204, 216, 233, 0.96);
  background: rgba(255, 255, 255, 0.92);
  color: var(--ink-800);
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-primary,
.btn-ghost,
.btn-pill,
.text-btn {
  min-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  color: #ffffff;
  border: 0;
  background: linear-gradient(135deg, var(--brand-primary), #29678c);
  box-shadow: 0 12rpx 28rpx rgba(31, 77, 127, 0.24);
}

.btn-ghost,
.btn-pill,
.text-btn {
  color: var(--ink-800);
  border: 1rpx solid rgba(199, 214, 232, 0.96);
  background: rgba(240, 246, 255, 0.9);
}

button.btn-primary::after,
button.btn-ghost::after,
button.btn-pill::after,
button.text-btn::after,
button.global-fab::after {
  border: none;
}

.input {
  width: 100%;
  min-width: 0;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(196, 210, 228, 0.98);
  background: rgba(248, 251, 255, 0.94);
  color: var(--ink-950);
  font-size: 28rpx;
  line-height: 88rpx;
}

textarea,
.editor,
.comment-input,
.ask-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(196, 210, 228, 0.98);
  background: rgba(248, 251, 255, 0.94);
  color: var(--ink-950);
  font-size: 27rpx;
  line-height: 1.65;
}

.empty {
  padding: 24rpx 0;
  text-align: center;
  color: var(--ink-500);
  font-size: 26rpx;
  line-height: 1.6;
}

button.global-fab,
.global-fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(166rpx + env(safe-area-inset-bottom));
  width: 88rpx;
  height: 88rpx;
  max-width: 88rpx;
  max-height: 88rpx;
  min-width: 88rpx;
  min-height: 88rpx;
  padding: 0;
  line-height: 88rpx;
  text-indent: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1e5d84, #31b48f);
  box-shadow: var(--shadow-float);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  z-index: 90;
}

.global-fab-plus {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  font-size: 56rpx;
  line-height: 1;
  font-weight: 700;
  text-align: center;
  transform: translateY(-2rpx);
}
