APP_NAME=Campus Smart Service Backend
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5500,http://localhost:5500,null

POSTGRES_URL=sqlite:///./campus.db
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=
QDRANT_COLLECTION=campus_kb_chunks

JWT_SECRET=change-this-in-production
JWT_EXPIRE_MINUTES=720
JWT_REFRESH_DAYS=14
BOOTSTRAP_DEMO_DATA=true

WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session
WECHAT_TIMEOUT_SECONDS=10
# Dev/test only. Production ignores mock mode.
WECHAT_MOCK_ENABLED=true

QA_PROVIDER=openai_compatible
QA_BASE_URL=https://api.siliconflow.cn/v1
QA_API_KEY=
QA_MODEL=Qwen/Qwen2.5-7B-Instruct
QA_TIMEOUT_SECONDS=30

RERANK_PROVIDER=none
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_API_KEY=
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B

EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT_SECONDS=25

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
